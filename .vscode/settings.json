{
    // Override token (syntax highlight) colors using the TextMate scoping system.
    "editor.tokenColorCustomizations": {
        // Theme-scoped overrides: keys matching "[*Light*]" / "[*Dark*]" apply only
        // when the active theme's name contains "Light" or "Dark" respectively.
        // These ensure search-match highlight text is readable on any theme.
        "[*Light*]": {
            "textMateRules": [
                {
                    "scope": "ref.matchtext",
                    "settings": {
                        "foreground": "#000"
                    }
                }
            ]
        },
        "[*Dark*]": {
            "textMateRules": [
                {
                    "scope": "ref.matchtext",
                    "settings": {
                        "foreground": "#fff"
                    }
                }
            ]
        },
        // Colors for inline test result decorations applied by the C++ TestMate
        // extension. Scopes are named after Google Test (the test framework), not
        // after the extension itself.
        "textMateRules": [
            {
                "scope": "googletest.failed",
                "settings": {
                    "foreground": "#f00"
                }
            },
            {
                "scope": "googletest.passed",
                "settings": {
                    "foreground": "#0f0"
                }
            },
            {
                "scope": "googletest.run",
                "settings": {
                    "foreground": "#0f0"
                }
            }
        ]
    },
    "cmake.configureOnOpen": false,
    "cmake.configureSettings": {
        "ENABLE_CLANG_TIDY": "ON"
    },
    "cmake.buildDirectory": "${workspaceFolder}/build",
    "cmake.deleteBuildDirOnCleanConfigure": false,
    "cmake.generator": "Ninja Multi-Config",
    "C_Cpp.intelliSenseEngine": "disabled",
    "C_Cpp.errorSquiggles": "disabled",
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
    "clangd.arguments": [
        "--compile-commands-dir=build",
        "--background-index",
        "--clang-tidy",
        "--completion-style=detailed",
        "--header-insertion=iwyu"
    ],
    "testMate.cpp.debug.configTemplate": "name:Tests (Debug, TestMate)"
}