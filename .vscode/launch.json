{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Sample (Windows)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/native/${input:buildType}/${input:target}.exe",
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/native/${input:buildType}",
            "console": "integratedTerminal",
            "presentation": {
                "group": "Windows",
                "order": 1
            }
        },
        {
            "name": "Sample (GDB, Linux)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/native/${input:buildType}/${input:target}",
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/native/${input:buildType}",
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set disassembly flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "environment": [
                {
                    "name": "ASAN_OPTIONS",
                    "value": "detect_leaks=1:abort_on_error=0"
                },
                {
                    "name": "UBSAN_OPTIONS",
                    "value": "abort_on_error=0:print_stacktrace=1"
                }
            ],
            "presentation": {
                "group": "Linux",
                "order": 1
            }
        },
        {
            "name": "Sample (LLDB, macOS)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/native/${input:buildType}/${input:target}",
            "cwd": "${workspaceFolder}/build/native/${input:buildType}",
            "env": {
                "ASAN_OPTIONS": "abort_on_error=0",
                "UBSAN_OPTIONS": "abort_on_error=0:print_stacktrace=1"
            },
            "presentation": {
                "group": "macOS",
                "order": 1
            }
        }
    ],
    "inputs": [
        {
            "id": "buildType",
            "type": "pickString",
            "description": "Select build folder",
            "options": [
                "Debug",
                "Release",
                "Sanitize"
            ],
            "default": "Debug"
        },
        {
            "id": "target",
            "type": "pickString",
            "description": "Select executable",
            "options": [
                "Triangle",
                "EmTriangle",
                "Viewer",
                "Orbit"
            ],
            "default": "Viewer"
        }
    ]
}
